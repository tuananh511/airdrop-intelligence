# ==== Telegram ====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==== AI Provider ====
# Provider hiện hỗ trợ: gemini (mặc định). Thiết kế sẵn interface để thêm openrouter/openai sau.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# ==== Bật/tắt tính năng ====
# Bật chấm điểm AI (V3). Để false nếu chỉ muốn crawl + gửi Telegram (V1) mà chưa cần AI.
ENABLE_AI_SCORING=false

# ==== HTTP ====
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3

# ==== Logging ====
LOG_LEVEL=INFO
